EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_app_password

# ─────────────────────────────────────────────────────────────────────────────
# .env — Chat Room App
# JANGAN commit file ini ke Git! Pastikan .env ada di .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase Database ─────────────────────────────────────────────────────────
# Ambil dari: Supabase Dashboard → Settings → Database → Connection string
#
# DATABASE_URL  → pakai "Transaction" pooler  (port 6543) — untuk runtime query
# DIRECT_URL    → pakai "Session" / direct    (port 5432) — untuk prisma migrate

DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ── Supabase Client (untuk Realtime & Presence) ───────────────────────────────
# Ambil dari: Supabase Dashboard → Settings → API
PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# ── OAuth — Google ────────────────────────────────────────────────────────────
# Buat di: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:5173/auth/callback/google
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# ── OAuth — GitHub ────────────────────────────────────────────────────────────
# Buat di: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:5173/auth/callback/github
GITHUB_CLIENT_ID="Iv1.xxxx"
GITHUB_CLIENT_SECRET="xxxx"

# ── App Secret ────────────────────────────────────────────────────────────────
# Dipakai untuk sign session token — generate random string 32+ karakter
# Cara generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="your-super-secret-random-string-here"

# ── App URL ───────────────────────────────────────────────────────────────────
# Development
PUBLIC_APP_URL="http://localhost:5173"

# Production (ganti saat deploy ke Vercel)
# PUBLIC_APP_URL="https://your-app.vercel.app"
